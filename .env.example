# Postgres (used by docker-compose and the loader)
POSTGRES_USER=glrecon
POSTGRES_PASSWORD=glrecon
POSTGRES_DB=glrecon
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Synthetic data generation
GLRECON_SEED=42
GLRECON_DAYS=90
GLRECON_OUTPUT_DIR=./data/raw

# Slack alerting (Phase 3 — leave blank to disable)
SLACK_WEBHOOK_URL=
